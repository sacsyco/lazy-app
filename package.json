{
  "name": "lazy-app",
  "version": "0.1.0",
  "description": "The Lazy App - Modern Life, Simplified. Real Help, Right Around the Corner.",
  "type": "module",
  "main": "backend/src/index.js",
  "scripts": {
    "dev": "node --watch backend/src/index.js",
    "start": "node backend/src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,json}\"",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc --project backend/tsconfig.json",
    "build:frontend": "cd frontend && npm run build",
    "docker:build": "docker build -t lazy-app .",
    "docker:run": "docker run -p 3000:3000 -p 5000:5000 lazy-app"
  },
  "keywords": [
    "gig-economy",
    "local-marketplace",
    "zip-code",
    "services",
    "tasks"
  ],
  "author": "sacsyco",
  "license": "Proprietary",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase": "^10.0.0",
    "stripe": "^14.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "axios": "^1.6.2",
    "socket.io": "^4.7.0",
    "jsonwebtoken": "^9.1.1",
    "bcryptjs": "^2.4.3",
    "pdfkit": "^0.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.8",
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "nodemon": "^3.0.2"
  }
}
